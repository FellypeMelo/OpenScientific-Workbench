# TEMPLATE ONLY. This file documents the exact Secret shape/keys
# `backend-deployment.yaml` expects (via `envFrom.secretRef`) -- it is named
# `.example` specifically so it is never mistaken for a real, appliable
# manifest and never accidentally applied or committed with real values.
#
# To actually deploy:
#   1. Copy this file to `secret.yaml` (gitignored -- do NOT commit real
#      secrets, here or anywhere else in this repo).
#   2. Replace every `REPLACE_ME*` placeholder with a real value.
#   3. `kubectl apply -f k8s/secret.yaml`
#
# In any real deployment, prefer NOT hand-editing a plaintext Secret manifest
# at all: use `kubectl create secret generic osw-backend-secrets
# --from-literal=KEY=value ...`, or better, a proper secrets pipeline (Vault
# annotations/CSI driver, Sealed Secrets, External Secrets Operator) so
# plaintext values never touch a local file or shell history in the first
# place. This template exists only to document the expected keys.
#
# IMPORTANT -- JWT_SECRET and multi-replica correctness: `backend-deployment.yaml`
# runs multiple `osw-backend` replicas. `backend/src/presentation/middleware/jwt_auth.py`
# generates a random, per-process ephemeral signing secret ONLY when
# `JWT_SECRET` is unset AND `ENV != "production"` -- since `configmap.yaml`
# sets `ENV=production`, an unset `JWT_SECRET` here instead makes every
# backend pod refuse to start (fail loudly, by design -- see that module's
# `_resolve_signing_secret` docstring). Set a real, identical `JWT_SECRET`
# here so all replicas verify each other's tokens.
apiVersion: v1
kind: Secret
metadata:
  name: osw-backend-secrets
  labels:
    app: osw-backend
type: Opaque
stringData:
  # postgresql+asyncpg://<user>:<password>@<host>:5432/<db> -- see
  # `backend/src/infrastructure/config.py`'s `DATABASE_URL` field.
  DATABASE_URL: "postgresql+asyncpg://REPLACE_USER:REPLACE_PASSWORD@REPLACE_POSTGRES_HOST:5432/osw_session_db"

  # redis://:<password>@<host>:6379/0
  REDIS_URL: "redis://:REPLACE_PASSWORD@REPLACE_REDIS_HOST:6379/0"

  NEO4J_PASSWORD: "REPLACE_ME"

  # Generate with, e.g.: `openssl rand -hex 32`
  JWT_SECRET: "REPLACE_ME_WITH_A_LONG_RANDOM_SECRET"

  # --- Optional: Vault secrets manager (falls back to mocked HPC dispatch if
  # unset -- see infrastructure/hpc/slurm_dispatcher.py) ---
  VAULT_TOKEN: ""

  # --- Optional: HPC / Slurm dispatch over SSH. All three must be set
  # together for real `sbatch` dispatch, otherwise a deterministic mock job id
  # is used instead. SLURM_SSH_KEY_PATH must resolve to a real file INSIDE the
  # container -- this MVP does not wire up a matching Secret volume mount for
  # an actual private key file, only the path string; mounting the key itself
  # is left as future work (see k8s/README.md). ---
  SLURM_SSH_HOST: ""
  SLURM_SSH_USER: ""
  SLURM_SSH_KEY_PATH: ""

  # --- Optional LLM providers (BYOK) -- only the ones you intend to use need
  # a key configured. ---
  DEEPSEEK_API_KEY: ""
  GLM_API_KEY: ""
  ANTHROPIC_API_KEY: ""
  OPENAI_API_KEY: ""
