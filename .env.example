# OpenScientific-Workbench - root environment configuration example.
#
# Consumed by `docker-compose.yml` (the ONE canonical Compose stack --
# postgres/redis/neo4j/qdrant + backend + worker + frontend, with `vault`
# available behind the optional `advanced` profile). Copy this file to `.env`
# in the repo root and run:
#
#   cp .env.example .env
#   docker compose up --build
#
# Every value below already has a working local default baked into
# `docker-compose.yml` itself (`${VAR:-default}`), so this file is optional
# for a first local run -- but copy it anyway and edit the passwords/secrets
# below before leaving this running on anything other than your own machine.
# The shipped defaults are REAL BUT WEAK local-dev credentials, appropriate
# only for this project's locked architecture (one trusted local server, not
# a shared network or multi-tenant deployment).
#
# Never commit a real `.env` file -- it is gitignored on purpose (see the
# `!.env.example` / `!**/.env.example` negation in `.gitignore`, which is what
# keeps *this* template file committed while blocking any real `.env`).
#
# This mirrors `backend/.env.example` (used for running the backend directly
# with `uvicorn`, outside Docker) but adds the datastore *credentials* that
# `docker-compose.yml` also needs to hand to postgres/neo4j themselves.
#
# Caveat: avoid `@`, `:`, `/`, or `#` characters in POSTGRES_PASSWORD -- it is
# interpolated directly into a `postgresql+asyncpg://` URL in
# `docker-compose.yml` without percent-encoding.

# --- Postgres (relational persistence) ---
POSTGRES_DB=osw_session_db
POSTGRES_USER=osw_user
POSTGRES_PASSWORD=osw_password_change_me

# --- Neo4j (GraphRAG knowledge graph) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password_change_me

# --- Redis (job queue + rate limiting cache) ---
# No password by default -- Redis is only reachable inside the Compose
# network (not published beyond localhost) on this project's locked
# single-local-server architecture. Add auth yourself (a `--requirepass` on
# the `redis` service's `command:` in `docker-compose.yml`, plus a matching
# `redis://:<password>@redis:6379/0` REDIS_URL) if this ever runs on a
# shared/multi-tenant host.

# --- Auth (JWT middleware) ---
# The placeholder below is an obviously-fake value (matching
# `docker-compose.yml`'s own inline fallback for this var) so the stack boots
# with zero setup -- it is NOT meant to be used as-is beyond your own single
# local machine. Generate and set a real one before this is reachable by
# anyone else: `openssl rand -hex 32`
JWT_SECRET=change-me-local-dev-jwt-secret-please-rotate
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# --- CORS ---
# Comma-separated origins allowed to call the backend from a browser. Must
# match wherever the frontend is actually served from (the browser's origin,
# not the in-network Docker service name).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Rate limiting (optional, defaults shown) ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- HPC job dispatch backend ---
# "local" (default): jobs run through the `worker` service in
# `docker-compose.yml`, a Redis-backed RQ queue -- no extra setup needed.
# "slurm": dispatches over SSH to a real Slurm cluster via the existing
# SlurmSSHDispatcher/VaultClient code (dormant unless you configure the
# SLURM_SSH_*/VAULT_* vars below AND start the `vault` service with
# `docker compose --profile advanced up -d vault`).
HPC_BACKEND=local

# --- Sandboxed code execution runtime ---
# "bubblewrap" (default): unprivileged Linux sandboxing via the `bwrap`
# binary installed in `backend/Dockerfile` (replaces the earlier gVisor
# design). This is a security boundary -- if real isolation is unavailable,
# the sandbox adapter must fail loudly rather than silently run unsandboxed.
SANDBOX_RUNTIME=bubblewrap

# --- Secrets manager (Vault) -- ADVANCED / OPTIONAL. Only needed for the
# dormant Slurm-SSH HPC path above (HPC_BACKEND=slurm). Falls back to mocked
# HPC dispatch when VAULT_TOKEN is left empty, see
# backend/src/infrastructure/config.py. VAULT_ADDR defaults (in
# docker-compose.yml) to the in-network `vault` service, which is NOT started
# by a plain `docker compose up` -- opt in with
# `docker compose --profile advanced up -d vault`, then see
# `docker/vault-entrypoint.sh` for how VAULT_TOKEN gets minted on first boot. ---
# VAULT_ADDR=http://vault:8200
VAULT_TOKEN=
VAULT_SSH_ROLE=hpc-ssh-role

# --- HPC / Slurm dispatch -- optional; all three must be set together for
# real `sbatch` dispatch over SSH, otherwise a deterministic mock job id is
# used instead (see infrastructure/hpc/slurm_dispatcher.py). Only relevant
# when HPC_BACKEND=slurm above. ---
SLURM_SSH_HOST=
SLURM_SSH_USER=
SLURM_SSH_KEY_PATH=

# --- LLM providers (BYOK) -- optional: only the ones you intend to use need
# a key configured ---
DEEPSEEK_API_KEY=
GLM_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Frontend build/runtime ---
# Where the *browser* can reach the backend (published host port below), not
# the in-network `backend` service name -- this gets inlined into the Next.js
# client bundle at build time (see frontend/Dockerfile).
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Published host ports (optional, defaults shown) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000
VAULT_PORT=8200

# --- Misc ---
ENV=production
LOG_LEVEL=INFO
