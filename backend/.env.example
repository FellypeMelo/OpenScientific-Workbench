# OpenScientific-Workbench backend - example environment configuration.
# Copy this file to `.env` (same directory) and fill in real values for local
# development. Never commit a real `.env` file - it is gitignored on purpose.
# See src/infrastructure/config.py for the pydantic-settings model these map to.

# --- Relational persistence (Fase 1 - Postgres wiring) ---
# Defaults to a local SQLite file (via aiosqlite) when unset, so the app can boot
# without a running Postgres instance. Use a real Postgres URL in staging/prod, e.g.:
# DATABASE_URL=postgresql+asyncpg://osw_user:osw_password@localhost:5432/osw_session_db
DATABASE_URL=sqlite+aiosqlite:///./osw_dev.db

# --- Cache / rate limiting (Fase 2 - middleware) ---
REDIS_URL=redis://localhost:6379/0

# --- Knowledge graph (Fase 4 - GraphRAG) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# --- Vector store ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- HPC job dispatch backend (Fase 5 - job queue abstraction) ---
# "local" (default): a Redis-backed RQ queue, consumed by
# `python scripts/run_worker.py` (see `docker-compose.yml`'s `worker`
# service) -- no extra infra to stand up beyond the Redis instance every
# other adapter here already uses.
# "slurm": dispatches over SSH to a real Slurm cluster via the existing
# SlurmSSHDispatcher/VaultClient code below (dormant unless VAULT_TOKEN and
# the SLURM_SSH_* vars are actually configured).
HPC_BACKEND=local

# --- Sandboxed code execution runtime (replaces the earlier gVisor design) ---
# "bubblewrap" (default): shells out to the `bwrap` binary (installed via
# `backend/Dockerfile`) for unprivileged Linux sandboxing. This is a security
# boundary: if real isolation is unavailable, the sandbox adapter must fail
# loudly rather than silently execute unsandboxed.
SANDBOX_RUNTIME=bubblewrap

# --- Secrets manager (Fase 4 - Vault) -- ADVANCED / OPTIONAL. Only needed for
# the Slurm HPC path above (HPC_BACKEND=slurm); irrelevant otherwise. In the
# Docker Compose stack, `VAULT_ADDR` points at the `vault` service, which
# lives behind the `advanced` Compose profile (`docker compose --profile
# advanced up -d vault`) -- see `docker/vault-entrypoint.sh` for how the
# first real VAULT_TOKEN gets minted. ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=change-me
# Vault SSH secrets engine role name used to issue ephemeral OTP SSH credentials
# (see `vault write ssh/roles/<name> key_type=otp ...`). Not a secret.
VAULT_SSH_ROLE=hpc-ssh-role

# --- HPC / Slurm dispatch (Fase 4 - paramiko SSH) ---
# All three must be set for real `sbatch` dispatch over SSH; if any is missing,
# the dispatcher falls back to a mock job id (see infrastructure/hpc/slurm_dispatcher.py).
# Only relevant when HPC_BACKEND=slurm above.
SLURM_SSH_HOST=
SLURM_SSH_USER=
SLURM_SSH_KEY_PATH=

# --- Auth (Fase 2 - JWT middleware) ---
# Required in any non-local/dev environment. No default is provided by the app -
# generate a strong random secret, e.g.: `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# --- LLM providers (BYOK - Fase 3 streaming) ---
# All optional: only the providers you intend to use need a key configured.
DEEPSEEK_API_KEY=
GLM_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
